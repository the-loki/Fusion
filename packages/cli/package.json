{
  "name": "@dustinbyrne/kb",
  "version": "0.4.0",
  "type": "module",
  "keywords": [
    "pi-package"
  ],
  "bin": {
    "kb": "./dist/bin.js"
  },
  "pi": {
    "extensions": [
      "./dist/extension.js"
    ],
    "image": "https://raw.githubusercontent.com/dustinbyrne/kb/main/demo/screenshot.png"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist/**/*.js",
    "dist/**/*.d.ts",
    "dist/**/*.d.ts.map",
    "dist/**/*.js.map",
    "dist/client/**",
    "README.md"
  ],
  "scripts": {
    "dev": "tsx src/bin.ts",
    "build": "tsup",
    "build:exe": "bun run build.ts",
    "build:exe:all": "bun run build.ts --all",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@mariozechner/pi-ai": "^0.62.0",
    "@mariozechner/pi-coding-agent": "^0.62.0",
    "express": "^5.1.0",
    "multer": "^2.1.1"
  },
  "peerDependencies": {
    "@mariozechner/pi-ai": "*",
    "@mariozechner/pi-coding-agent": "*",
    "@sinclair/typebox": "*"
  },
  "peerDependenciesMeta": {
    "@mariozechner/pi-ai": {
      "optional": true
    },
    "@mariozechner/pi-coding-agent": {
      "optional": true
    },
    "@sinclair/typebox": {
      "optional": true
    }
  },
  "devDependencies": {
    "@kb/core": "workspace:*",
    "@kb/dashboard": "workspace:*",
    "@kb/engine": "workspace:*",
    "@sinclair/typebox": "^0.34.0",
    "@vitest/coverage-v8": "^3.1.0",
    "tsup": "^8.5.1",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^3.1.0",
    "yaml": "^2.8.3"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/dustinbyrne/kb"
  }
}
